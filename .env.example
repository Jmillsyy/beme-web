# Copy to .env (local) or set these in the Vercel project settings.
# Every public var must be prefixed PUBLIC_ to be readable in the
# browser-side Astro build.

# Plausible analytics. Set this to your verified domain to switch
# analytics on in production. Leave it unset to keep analytics off.
# The script is cookie-less, so no consent banner is required.
PUBLIC_ANALYTICS_DOMAIN=beme.com.au
