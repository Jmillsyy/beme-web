---
import BaseLayout from '../layouts/BaseLayout.astro'
import CTA from '../components/CTA.astro'
import SectionGlow from '../components/SectionGlow.astro'

const appUrl = 'https://app.bemeapp.app'

// Same tri-colour rhythm as the rest of the site. Visual /
// 3D-flavoured reasons land on sky; "win the order" /
// activation messages on amber; brand-aligned points on orange.
const reasons = [
  { title: 'Compete on more than price and delivery', body: 'Every supplier in your patch is already competing on tonnage and turnaround. Accurate estimation and a 3D view give your reps something the competition can\'t put in front of the customer.', accent: 'sky' as const },
  { title: 'Win the order in the same conversation', body: 'Customers commit faster when they can see the build. Swap "we\'ll send a quote" for "here\'s exactly what you need, here\'s what it looks like", without sending the job out to anyone.', accent: 'amber' as const },
  { title: 'No estimating team needed', body: 'Your existing sales team uses Beme themselves. No new hires, no QS training, no quotes sitting in someone else\'s inbox.', accent: 'beme' as const },
  { title: 'Your branding on every export', body: 'PDFs go out with your logo, your company details, your reference numbers. The customer sees your service, not ours.', accent: 'amber' as const },
  { title: 'Shared library, consistent quotes', body: 'Every estimator on the team draws from the same wall types, supply rates, and lintel catalogue. Three reps quoting the same job land on the same number.', accent: 'beme' as const },
  { title: 'One dashboard for every job', body: 'See every estimate across the team, who\'s working on what, what\'s been quoted, what\'s landed. One reference number per job, end to end.', accent: 'sky' as const },
]
function dotClass(a: 'beme' | 'amber' | 'sky'): string {
  if (a === 'amber') return 'bg-amber-400'
  if (a === 'sky') return 'bg-sky-400'
  return 'bg-beme-400'
}
---

<BaseLayout
  title="Beme for suppliers: estimation as a sales tool"
  description="Add accurate estimation and 3D visualisation to your sales process. Win more orders without setting up an estimating team."
>
  <section class="relative overflow-hidden">
    {/* Sky glow ties to the "3D walkthrough"/visual sales-tool
        framing this page leads with, a small cool-coloured nod
        to the feature the page is selling. */}
    <SectionGlow color="sky" position="top-right" intensity="subtle" />
    <div class="container-tight text-center max-w-3xl mx-auto relative" style="padding-top: clamp(5rem, 7vw, 9rem); padding-bottom: clamp(3rem, 5vw, 5rem);">
    <div class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4">
      For suppliers
    </div>
    <h1 class="text-4xl md:text-5xl font-bold text-ink-50 tracking-tight leading-[1.1]">
      Make estimation part of how you sell.
    </h1>
    <p class="text-base md:text-lg text-ink-300 mt-7 leading-relaxed">
      Your customers want certainty before they commit. Anyone can
      quote on tonnage. The suppliers who close the order send back
      an accurate brick and block schedule and a 3D walkthrough the
      same day, with their branding on every page, without setting
      up an estimating team. Beme adds that capability to the sales
      process you already run.
    </p>
    <div class="flex flex-wrap justify-center gap-3 mt-10">
      <button
        type="button"
        data-checkout
        data-plan="team"
        data-source="for-suppliers"
        class="px-6 py-3 rounded-md bg-beme-500 hover:bg-beme-400 transition-colors font-medium cursor-pointer"
        style="color: #000;"
      >
        Start free trial
      </button>
      <a
        href="mailto:hello@beme.com.au?subject=Beme for suppliers, chat"
        class="px-6 py-3 rounded-md border border-ink-600 text-ink-200 hover:bg-ink-800 transition-colors"
      >
        Talk to us
      </a>
    </div>
    </div>
  </section>

  <section class="container-tight" style="padding-block: clamp(4rem, 7vw, 8rem);">
    <div class="grid md:grid-cols-2 gap-x-16 gap-y-14 max-w-5xl mx-auto">
      {
        reasons.map((r) => (
          <div>
            <div class="flex items-center gap-3 mb-1">
              <span class={`inline-block w-1.5 h-1.5 rounded-full ${dotClass(r.accent)}`} aria-hidden="true" />
              <h3 class="text-lg font-semibold text-ink-50">{r.title}</h3>
            </div>
            <p class="text-[15px] text-ink-300 mt-3 leading-relaxed">{r.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <CTA
    title="See Beme in your sales pitch."
    body="Set up a free org trial. Run it past one of your reps. Decide from there."
    ctaLabel="Start free trial"
    checkoutPlan="team"
    checkoutSource="for-suppliers-cta"
  />
</BaseLayout>
