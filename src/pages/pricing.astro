---
import BaseLayout from '../layouts/BaseLayout.astro'
import PricingCard from '../components/PricingCard.astro'
import CTA from '../components/CTA.astro'
import SectionGlow from '../components/SectionGlow.astro'
import { pricingFaqs as faqs, faqJsonLd } from '../data/faqs'

const appUrl = 'https://app.bemeapp.app'
---

<BaseLayout title="Pricing" description="Plans for brick and block estimators. Monthly, no contract, cancel anytime." jsonLd={faqJsonLd(faqs)}>
  <section class="relative overflow-hidden container-tight text-center" style="padding-top: clamp(5rem, 7vw, 9rem); padding-bottom: clamp(3rem, 5vw, 5rem);">
    <SectionGlow color="beme" position="top" intensity="subtle" />
    <div class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4">Pricing</div>
    <h1 class="text-4xl md:text-5xl font-bold text-ink-50 tracking-tight">Pick your plan.</h1>
    <p class="text-base md:text-lg text-ink-300 mt-5 max-w-2xl mx-auto leading-relaxed">
      Basic to get estimating, Pro when you are running serious volume. Monthly, no contract, cancel anytime.
    </p>
  </section>

  {/* Two individual plans, billed monthly. Organisation tiers and annual
      billing are parked for now (only individual + monthly is live), so
      the page is a straight two-card comparison with no toggles. */}
  <section class="container-tight" style="padding-bottom: clamp(1rem, 3vw, 2rem);">
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <PricingCard
        name="Basic"
        tagline="For estimating your own jobs."
        price="$49"
        cadence="/month"
        features={['One user', 'Up to 10 PDF exports per month', 'Full estimating engine, 3D view, supply schedule', 'Per-project reference numbers', 'Email support']}
        ctaLabel="Start free"
        ctaHref={`${appUrl}?source=pricing-basic`}
        checkoutPlan="starter"
        checkoutSource="pricing-basic"
      />
      <PricingCard
        name="Pro"
        tagline="For full-time estimators running serious volume."
        price="$199"
        cadence="/month"
        features={['One user', 'Unlimited active projects', 'Branded PDF exports', 'Saved templates + supply library', 'Priority email support', 'Best-fit for 20+ estimates a week']}
        ctaLabel="Start free trial"
        ctaHref={`${appUrl}?source=pricing-pro&plan=pro`}
        checkoutPlan="pro"
        checkoutSource="pricing-pro"
        featured
      />
    </div>
  </section>

  {/* Plain-language FAQ to head off common pre-purchase questions.
      `id="faq"` matches the nav anchor (#faq). */}
  <section id="faq" class="container-tight" style="padding-block: clamp(5rem, 8vw, 10rem);">
    <h2 class="text-2xl md:text-3xl font-bold text-ink-50 text-center mb-12">Common questions.</h2>
    <div class="max-w-3xl mx-auto space-y-5">
      {faqs.map((item) => (
        <details class="border border-ink-700 rounded-lg bg-ink-800/40 overflow-hidden group">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-ink-100 font-medium hover:bg-ink-800/70">{item.q}<span class="text-beme-400 transition-transform group-open:rotate-45">+</span></summary>
          <div class="px-5 pb-4 text-sm text-ink-300 leading-relaxed">{item.a}</div>
        </details>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>
