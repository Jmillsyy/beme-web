---
import BaseLayout from '../layouts/BaseLayout.astro'

// Contact page — three ways to get in touch (email, suppliers chat,
// support). Kept as a single short page; no contact form because a
// form here would just send an email anyway and adds a backend
// dependency for marginal UX benefit. Mailto links land in the
// visitor's email client pre-filled with the right subject line.

const appUrl = 'https://app.beme.com.au'
---

<BaseLayout
  title="Contact — Beme"
  description="Get in touch with Beme — for questions about the product, a supplier demo, or bug reports."
>
  <section
    class="container-tight max-w-3xl mx-auto"
    style="padding-top: clamp(5rem, 7vw, 9rem); padding-bottom: clamp(4rem, 6vw, 6rem);"
  >
    <div class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4">
      Contact
    </div>
    <h1 class="text-4xl md:text-5xl font-bold text-ink-50 tracking-tight">
      Get in touch.
    </h1>
    <p class="text-base md:text-lg text-ink-300 mt-5 leading-relaxed">
      A real person reads every email. We aim to get back to you
      within one business day — usually faster.
    </p>
  </section>

  <section
    class="container-tight max-w-3xl mx-auto"
    style="padding-bottom: clamp(5rem, 8vw, 10rem);"
  >
    <div class="grid md:grid-cols-2 gap-6">
      {/* General contact — primary card */}
      <div
        class="p-8 rounded-2xl border border-ink-700 bg-ink-800/40 lift reveal md:col-span-2"
      >
        <div
          class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-3"
        >
          General
        </div>
        <h2 class="text-2xl font-semibold text-ink-50">
          Email <a
            href="mailto:hello@beme.com.au"
            class="text-beme-400 hover:text-beme-300 underline"
            >hello@beme.com.au</a
          >
        </h2>
        <p class="text-[15px] text-ink-300 mt-3 leading-relaxed">
          Product questions, account help, bug reports, feature
          requests — anything goes. We read everything.
        </p>
      </div>

      {/* Suppliers — specific routing */}
      <div class="p-8 rounded-2xl border border-ink-700 bg-ink-800/40 lift reveal">
        <div
          class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-3"
        >
          For suppliers
        </div>
        <h3 class="text-xl font-semibold text-ink-50">
          Sales-tool demo
        </h3>
        <p class="text-[15px] text-ink-300 mt-3 leading-relaxed">
          Want to see Beme in your sales process before signing up?
          We'll walk you through it.
        </p>
        <a
          href="mailto:hello@beme.com.au?subject=Beme for suppliers — demo request"
          class="inline-block mt-5 text-sm font-medium text-beme-400 hover:text-beme-300 transition-colors"
        >
          Request a demo →
        </a>
      </div>

      {/* Existing customers — support */}
      <div class="p-8 rounded-2xl border border-ink-700 bg-ink-800/40 lift reveal">
        <div
          class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-3"
        >
          Existing customers
        </div>
        <h3 class="text-xl font-semibold text-ink-50">
          Support
        </h3>
        <p class="text-[15px] text-ink-300 mt-3 leading-relaxed">
          Logged in already? The fastest help is from inside the app
          — your project context comes through automatically.
        </p>
        <a
          href={`${appUrl}/settings`}
          class="inline-block mt-5 text-sm font-medium text-beme-400 hover:text-beme-300 transition-colors"
        >
          Open Settings in the app →
        </a>
      </div>
    </div>

    <p class="text-sm text-ink-400 mt-12 text-center">
      Beme is built in Australia. Business hours AEST / AEDT.
    </p>
  </section>
</BaseLayout>
