---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import BuildTour from '../components/BuildTour.astro'
import Pillar from '../components/Pillar.astro'
import AudienceBlock from '../components/AudienceBlock.astro'
import HowItWorks from '../components/HowItWorks.astro'
import HomeFaq from '../components/HomeFaq.astro'
import CTA from '../components/CTA.astro'
import { homeFaqs, faqJsonLd } from '../data/faqs'

// Inline SVG icons kept here so the Pillar component stays
// presentational. Outline weight (1.5) reads well at the 40px
// chip size and matches Lucide / Heroicons stroke conventions.
const checkIcon = `
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
`
const boltIcon = `
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
  </svg>
`
const cubeIcon = `
  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
    <line x1="12" y1="22.08" x2="12" y2="12"></line>
  </svg>
`
---

<BaseLayout
  title="Beme: Brick and block estimates that match what you build"
  jsonLd={faqJsonLd(homeFaqs)}
>
  <Hero />

  <BuildTour />

  {/* Three pillars, the positioning condensed into three cards. */}
  <section class="container-tight" style="padding-block: clamp(5rem, 8vw, 10rem);">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="flex items-center justify-center gap-2 text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4">
        <svg width="16" height="9" viewBox="0 0 104 56" aria-hidden="true" style="color: var(--color-beme-500);"><path fill-rule="evenodd" clip-rule="evenodd" fill="currentColor" d="M9 0 H95 A9 9 0 0 1 104 9 V47 A9 9 0 0 1 95 56 H9 A9 9 0 0 1 0 47 V9 A9 9 0 0 1 9 0 Z M15 11 H42 A4 4 0 0 1 46 15 V41 A4 4 0 0 1 42 45 H15 A4 4 0 0 1 11 41 V15 A4 4 0 0 1 15 11 Z M62 11 H89 A4 4 0 0 1 93 15 V41 A4 4 0 0 1 89 45 H62 A4 4 0 0 1 58 41 V15 A4 4 0 0 1 62 11 Z"/></svg>
        Why estimators choose Beme
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-ink-50 tracking-tight">
        Built for brick and block. Nothing else.
      </h2>
      <p class="text-base md:text-lg text-ink-300 mt-5 leading-relaxed">
        Most takeoff tools cover every trade at the surface. Beme
        goes deep on one, every rule, every quirk, every detail a
        brickie or blocklayer memorises over the years, baked into
        the software.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      <Pillar
        title="Your input equals the output."
        body="Every wall you draw is calculated to your specifications, bond, corners, openings, lintels and all. What's on screen is what's on the order. Nothing assumed, nothing rounded."
        iconSvg={checkIcon}
        iconBg="beme"
      />
      <Pillar
        title="Set it up once, reuse it on every job."
        body="Trace the architect's PDF, drop in wall types you've already saved, walk away with a full schedule. The setup work happens once. Every future job picks up where the last one left off."
        iconSvg={boltIcon}
        iconBg="amber"
      />
      <Pillar
        title="A 3D view the customer can read."
        body="A live model of every wall, opening, lintel and sill, built straight from your trace. Spot the wall you forgot before the order goes out. Show the build before the trucks turn up."
        iconSvg={cubeIcon}
        iconBg="sky"
      />
    </div>
  </section>

  {/* "How it works", numbered 3-step process. */}
  <HowItWorks />

  {/* Two feature-led blocks: the workflow, then the 3D view. Framed
      around what the app does, not who it's for. */}
  <AudienceBlock
    eyebrow="The workflow"
    title="Trace the plan. Get the whole order."
    body="Trace the architect's PDF, see the build in 3D, and walk away with a full supply schedule, all from the laptop or tablet you already carry. Your input equals the output: every wall calculated to your spec, every brick on the order."
    ctaLabel="See all features"
    ctaHref="/features"
    image="/home-tradies.png"
  />

  <AudienceBlock
    eyebrow="See it first"
    title="Catch the wall you forgot before you order."
    body="Every wall, opening, lintel and sill renders into a live 3D model as you draw. Spin it, check it, and fix the miss while it's still cheap, before the trucks turn up."
    ctaLabel="Read the guides"
    ctaHref="/guides"
    image="/features/3d.mp4"
    imageRight={false}
  />

  {/* 4 most-asked questions, covers visitors who don't make it to /pricing. */}
  <HomeFaq />

  <CTA />
</BaseLayout>
