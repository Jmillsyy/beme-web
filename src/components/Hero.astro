---
// Above-the-fold hero. Single column on mobile, two columns on
// desktop with the lede on the left and a hero image on the right.
// Drop your real screenshot at /public/hero.png and it'll render
// here. A wide 3D capture from the app works well.
import SectionGlow from './SectionGlow.astro'
const appUrl = 'https://app.beme.com.au'
---

<section class="relative overflow-hidden">
  <SectionGlow color="beme" position="top-left" />

  <div class="container-tight pb-28 md:pb-40 relative" style="padding-top: clamp(5rem, 7vw, 9rem);">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-beme-500/10 border border-beme-500/30 text-beme-300 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-beme-500"></span>
          Built for brick and block estimators
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-ink-50 leading-[1.05] tracking-tight">
          Estimates that match what you build.
        </h1>

        <p class="text-lg md:text-xl text-ink-300 mt-8 leading-relaxed max-w-xl">
          Trace the plan. See the build in 3D. Your input equals the
          output — every wall you draw is calculated to your
          specifications, every brick on screen is on the order.
        </p>

        <div class="flex flex-wrap gap-3 mt-10">
          <button
            type="button"
            data-checkout
            data-plan="starter"
            data-source="hero"
            class="inline-block px-6 py-3 rounded-md bg-beme-500 hover:bg-beme-400 transition-colors font-medium cursor-pointer"
            style="color: #000;"
          >
            Start free
          </button>
          <a
            href="/pricing"
            class="inline-block px-6 py-3 rounded-md border border-ink-600 text-ink-200 hover:bg-ink-800 transition-colors"
          >
            See pricing
          </a>
        </div>

        <p class="text-xs text-ink-500 mt-5">
          No credit card to start. Cancel anytime.
        </p>
      </div>

      <div class="relative">
        {/* Hero image — a 3D capture from the app at /public/hero.png.
            If the file is missing, the onerror swap hides the broken
            <img> and falls back to the placeholder div, so the page
            never renders a broken-image icon. */}
        <img
          src="/hero.png"
          alt="Beme 3D view of a brick wall — every brick on screen is on the supply schedule"
          class="block w-full h-auto aspect-[4/3] rounded-xl border border-ink-700 shadow-2xl shadow-beme-500/5 object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div
          class="aspect-[4/3] rounded-xl border border-ink-700 bg-ink-800 shadow-2xl shadow-beme-500/5 overflow-hidden items-center justify-center text-ink-500 text-sm"
          style="display: none;"
        >
          Drop your hero capture at /public/hero.png
        </div>
      </div>
    </div>
  </div>
</section>
