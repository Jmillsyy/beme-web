---
// One subscription tier. Highlighted version (`featured: true`) gets
// a brand-orange border + lifted shadow so the recommended plan
// pulls the eye. Bullet list is flexible, pass whatever lines
// matter for the tier.

interface Props {
  /** Short tier name. */
  name: string
  /** One-line who-it's-for under the name. */
  tagline: string
  /** Single-price headline (legacy / Enterprise "Contact us" mode).
   *  When the card supports both monthly + annual billing, use
   *  priceMonthly + priceAnnual instead. Leave empty for "Contact us". */
  price?: string
  /** Monthly billing price (e.g. "$49"). Shown when the page's
   *  billing toggle is on Monthly. */
  priceMonthly?: string
  /** Annual billing price as an amortised monthly figure (e.g. "$39"
   *  for $39/mo when billed annually). Shown when the page's billing
   *  toggle is on Annual. Same visual shape as the monthly price, 
   *  just the digit changes, so the eye latches on the saving. */
  priceAnnual?: string
  /** Cadence suffix (e.g. "/month"). Ignored when price is empty. */
  cadence?: string
  /** Bullet list of included features / limits. */
  features: string[]
  /** CTA button label. */
  ctaLabel: string
  /** CTA destination, used as fallback if checkoutPlan isn't set. */
  ctaHref: string
  /** Stripe plan id. When set, the CTA goes through Stripe Checkout
   *  via the data-checkout hook instead of plain link navigation.
   *  Adding a new plan id here is fine, the Stripe wiring upstream
   *  just reads `data-plan` off the button. */
  checkoutPlan?: 'starter' | 'pro' | 'team' | 'enterprise'
  /** Source tag passed to checkout for analytics. */
  checkoutSource?: string
  /** Visually elevate this tier as the recommended one. */
  featured?: boolean
}

const {
  name,
  tagline,
  price,
  priceMonthly,
  priceAnnual,
  cadence = '/month',
  features,
  ctaLabel,
  ctaHref,
  checkoutPlan,
  checkoutSource,
  featured = false,
} = Astro.props

// Dual-price mode shows both monthly + annual values; the page-level
// billing toggle picks which is visible via the [data-billing-show]
// hook below. Single-price mode is the legacy path (still used by
// Enterprise where there's no annual rate to show).
const hasDualPrice = !!priceMonthly && !!priceAnnual
---

<div
  class={`relative p-8 md:p-10 rounded-2xl border lift reveal ${
    featured
      ? 'border-beme-500/60 bg-ink-800 shadow-2xl shadow-beme-500/10'
      : 'border-ink-700 bg-ink-800/40'
  }`}
>
  {
    featured && (
      <div class="absolute -top-3 left-8 px-2.5 py-0.5 rounded bg-beme-500 text-ink-900 text-[10px] font-semibold uppercase tracking-wider">
        Most popular
      </div>
    )
  }

  <div class="text-xl font-semibold text-ink-50">{name}</div>
  <div class="text-sm text-ink-400 mt-2">{tagline}</div>

  <div class="mt-8">
    {
      hasDualPrice ? (
        <>
          {/* Monthly price, visible when [data-billing-mode="monthly"].
              The data-billing-show hook is targeted by the toggle JS in
              pricing.astro; CSS in the page picks which row shows. */}
          <div data-billing-show="monthly">
            <span class="text-5xl font-bold text-ink-50">{priceMonthly}</span>
            <span class="text-sm text-ink-400 ml-1">{cadence}</span>
          </div>
          {/* Annual price, amortised monthly. Same visual weight so the
              jump reads as a digit change, not a layout shift. The
              "billed annually" line below clarifies the cadence. */}
          <div data-billing-show="annual">
            <span class="text-5xl font-bold text-ink-50">{priceAnnual}</span>
            <span class="text-sm text-ink-400 ml-1">{cadence}</span>
            <p class="text-xs text-emerald-300 mt-1 font-medium">billed annually</p>
          </div>
        </>
      ) : price ? (
        <div>
          <span class="text-5xl font-bold text-ink-50">{price}</span>
          <span class="text-sm text-ink-400 ml-1">{cadence}</span>
        </div>
      ) : (
        <div class="text-2xl font-semibold text-ink-50">Contact us</div>
      )
    }
    {
      (price || hasDualPrice) && (
        <p class="text-xs text-ink-400 mt-2">
          14-day free trial. Card required, cancel anytime.
        </p>
      )
    }
  </div>

  <ul class="mt-8 space-y-3 text-[15px] text-ink-200">
    {
      features.map((f) => (
        <li class="flex items-start gap-2.5">
          <span class="text-beme-400 mt-0.5">✓</span>
          <span>{f}</span>
        </li>
      ))
    }
  </ul>

  {
    checkoutPlan ? (
      <button
        type="button"
        data-checkout
        data-plan={checkoutPlan}
        data-source={checkoutSource ?? `pricing-${checkoutPlan}`}
        class={`block w-full text-center mt-10 px-5 py-3 rounded-md font-medium text-sm transition-colors cursor-pointer ${
          featured
            ? 'bg-beme-500 hover:bg-beme-400'
            : 'border border-ink-600 text-ink-100 hover:bg-ink-700'
        }`}
        style={featured ? 'color: #000;' : ''}
      >
        {ctaLabel}
      </button>
    ) : (
      <a
        href={ctaHref}
        class={`block text-center mt-10 px-5 py-3 rounded-md font-medium text-sm transition-colors ${
          featured
            ? 'bg-beme-500 hover:bg-beme-400'
            : 'border border-ink-600 text-ink-100 hover:bg-ink-700'
        }`}
        style={featured ? 'color: #000;' : ''}
      >
        {ctaLabel}
      </a>
    )
  }
</div>
