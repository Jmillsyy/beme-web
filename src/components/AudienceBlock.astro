---
// A two-column feature / value section: an optional eyebrow tag, a
// headline, body and CTA, paired with a screenshot or clip. Lays out
// as two columns on desktop with the visual on alternating sides
// (controlled by `imageRight`) so the page reads as a rhythm rather
// than a stack of identical blocks.

interface Props {
  eyebrow: string
  title: string
  body: string
  ctaLabel: string
  ctaHref: string
  /** Where the visual sits on desktop. Defaults to right. */
  imageRight?: boolean
  /** Optional screenshot or short clip. When set it replaces the
   *  placeholder; an .mp4 / .mov / .webm renders as a muted autoplay loop. */
  image?: string
}

const {
  eyebrow,
  title,
  body,
  ctaLabel,
  ctaHref,
  imageRight = true,
  image,
} = Astro.props

const isVideo = image ? /\.(mp4|mov|webm)$/i.test(image) : false
---

<section class="container-tight" style="padding-block: clamp(5rem, 8vw, 10rem);">
  <div
    class={`grid md:grid-cols-2 gap-12 lg:gap-20 items-center reveal ${
      imageRight ? '' : 'md:flex-row-reverse md:[direction:rtl]'
    }`}
  >
    <div class={imageRight ? '' : '[direction:ltr]'}>
      <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4">
        <svg width="16" height="9" viewBox="0 0 104 56" aria-hidden="true" style="color: var(--color-beme-500);"><path fill-rule="evenodd" clip-rule="evenodd" fill="currentColor" d="M9 0 H95 A9 9 0 0 1 104 9 V47 A9 9 0 0 1 95 56 H9 A9 9 0 0 1 0 47 V9 A9 9 0 0 1 9 0 Z M15 11 H42 A4 4 0 0 1 46 15 V41 A4 4 0 0 1 42 45 H15 A4 4 0 0 1 11 41 V15 A4 4 0 0 1 15 11 Z M62 11 H89 A4 4 0 0 1 93 15 V41 A4 4 0 0 1 89 45 H62 A4 4 0 0 1 58 41 V15 A4 4 0 0 1 62 11 Z"/></svg>
        {eyebrow}
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-ink-50 leading-tight">
        {title}
      </h2>
      <p class="text-base md:text-lg text-ink-300 mt-5 leading-relaxed measure">{body}</p>
      <a
        href={ctaHref}
        class="inline-block mt-8 text-sm font-medium text-beme-400 hover:text-beme-300 transition-colors"
      >
        {ctaLabel} →
      </a>
    </div>

    <div class={imageRight ? '' : '[direction:ltr]'}>
      {
        image ? (
          isVideo ? (
            <video
              src={image}
              class="w-full h-auto rounded-2xl border border-ink-600 bg-ink-800"
              style="box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.14);"
              autoplay
              loop
              muted
              playsinline
              onerror="this.style.display='none'"
            />
          ) : (
            <img
              src={image}
              alt={title}
              class="w-full h-auto rounded-2xl border border-ink-600 bg-ink-800"
              style="box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.14);"
              loading="lazy"
            />
          )
        ) : (
          <div
            class="aspect-[4/3] rounded-2xl border border-ink-600 bg-ink-800 flex items-center justify-center text-ink-400 text-sm overflow-hidden"
            style="box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.14);"
          >
            [ Screenshot / video ]
          </div>
        )
      }
    </div>
  </div>
</section>
