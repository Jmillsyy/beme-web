---
// Homepage FAQ — the 4 questions visitors most often ask before
// they click Start free. Pricing page has the full FAQ; this is the
// scroll-friendly subset that catches people on the homepage who
// won't make it to /pricing. Each item is a native <details> for
// zero-JS expand/collapse — fast, accessible, no library.

const items = [
  {
    q: 'Do I need a credit card to start?',
    a: 'Yes — Stripe collects card details upfront for the 14-day free trial. You\'re not charged until the trial ends, and you can cancel anytime from your account settings without being billed.',
  },
  {
    q: 'What brick and block sizes does Beme support?',
    a: 'Whatever you order from. Wall types are library-agnostic: set your own brick or block dimensions per project and Beme builds the schedule around them. AU SEQ, US CMU, UK metric, custom supplier ranges — all work the same way.',
  },
  {
    q: 'How is Team different from a few Pro plans?',
    a: 'Team gives you a shared library (every estimator on the team picks from the same wall types and supply rates), a team dashboard, org-wide reference numbers, and your company details and logo on every exported PDF. Pro plans are isolated per user — fine for one tradie, not for a team.',
  },
  {
    q: 'Can I hand the customer a real document?',
    a: 'Yes. Exports are a polished multi-page PDF — assumptions, wall layout diagram, per-wall-type breakdowns, supply schedule, 3D view. Branded with your details on Team and Enterprise.',
  },
]
---

<section
  class="container-tight"
  style="padding-block: clamp(5rem, 8vw, 10rem);"
>
  <div class="text-center max-w-2xl mx-auto mb-12 reveal">
    <div
      class="text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4"
    >
      Frequently asked
    </div>
    <h2 class="text-3xl md:text-4xl font-bold text-ink-50 tracking-tight">
      Quick answers.
    </h2>
    <p class="text-base md:text-lg text-ink-300 mt-5 leading-relaxed">
      The questions most people ask before they start.
      <a
        href="/pricing#faq"
        class="text-beme-400 hover:text-beme-300 underline"
      >
        More on the pricing page
      </a>.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-4 reveal">
    {
      items.map((item) => (
        <details class="border border-ink-700 rounded-lg bg-ink-800/40 overflow-hidden group">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-ink-100 font-medium hover:bg-ink-800/70">
            {item.q}
            <span class="text-beme-400 transition-transform group-open:rotate-45">
              +
            </span>
          </summary>
          <div class="px-5 pb-4 text-sm text-ink-300 leading-relaxed">
            {item.a}
          </div>
        </details>
      ))
    }
  </div>
</section>
