---
// Homepage FAQ: the 4 questions visitors most often ask before they
// click Start free. Pricing page has the full FAQ; this is the
// scroll-friendly subset that catches people on the homepage who
// won't make it to /pricing. Each item is a native <details> for
// zero-JS expand/collapse: fast, accessible, no library. Content is
// shared with the FAQ structured data via src/data/faqs.ts.
import { homeFaqs as items } from '../data/faqs'
---

<section
  class="container-tight"
  style="padding-block: clamp(5rem, 8vw, 10rem);"
>
  <div class="text-center max-w-2xl mx-auto mb-12 reveal">
    <div
      class="flex items-center justify-center gap-2 text-xs uppercase tracking-wider text-beme-400 font-semibold mb-4"
    >
      <svg width="16" height="9" viewBox="0 0 104 56" aria-hidden="true" style="color: var(--color-beme-500);"><path fill-rule="evenodd" clip-rule="evenodd" fill="currentColor" d="M9 0 H95 A9 9 0 0 1 104 9 V47 A9 9 0 0 1 95 56 H9 A9 9 0 0 1 0 47 V9 A9 9 0 0 1 9 0 Z M15 11 H42 A4 4 0 0 1 46 15 V41 A4 4 0 0 1 42 45 H15 A4 4 0 0 1 11 41 V15 A4 4 0 0 1 15 11 Z M62 11 H89 A4 4 0 0 1 93 15 V41 A4 4 0 0 1 89 45 H62 A4 4 0 0 1 58 41 V15 A4 4 0 0 1 62 11 Z"/></svg>
      Frequently asked
    </div>
    <h2 class="text-3xl md:text-4xl font-bold text-ink-50 tracking-tight">
      Quick answers.
    </h2>
    <p class="text-base md:text-lg text-ink-300 mt-5 leading-relaxed">
      The questions most people ask before they start.
      <a
        href="/pricing#faq"
        class="text-beme-400 hover:text-beme-300 underline"
      >
        More on the pricing page
      </a>.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-4 reveal">
    {
      items.map((item) => (
        <details class="border border-ink-700 rounded-lg bg-ink-800/40 overflow-hidden group">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer text-ink-100 font-medium hover:bg-ink-800/70">
            {item.q}
            <span class="text-beme-400 transition-transform group-open:rotate-45">
              +
            </span>
          </summary>
          <div class="px-5 pb-4 text-sm text-ink-300 leading-relaxed">
            {item.a}
          </div>
        </details>
      ))
    }
  </div>
</section>
