---
// Top navigation. Light bar with the orange brand mark and CTA. The
// wordmark, links and buttons all use the Hanken Grotesk sans (Anthropic-
// style UI chrome); headlines and prose elsewhere stay in the serif. The
// site is light-mode only. Kept deliberately lean: three core links, with
// About living in the footer.

const links = [
  { href: '/features', label: 'Features' },
  { href: '/guides', label: 'Guides' },
  { href: '/pricing', label: 'Pricing' },
]
const appUrl = 'https://app.bemeapp.app'
---

<header
  class="bg-ink-800 border-b border-ink-600 sticky top-0 z-40"
>
  <div
    class="container-tight flex items-center justify-between gap-6 nav-inner"
  >
    <a
      href="/"
      class="group shrink-0 inline-flex items-center"
    >
      {/* Horizontal lockup: the two-block mark + BEME wordmark as ONE inline
          SVG (viewBox 256x56). The spacing/size/alignment are baked into SVG
          units, so this renders identically to the app's BemeLogo component -
          same artwork as the saved /beme-logo.svg asset. Mark is fixed orange;
          the word uses currentColor (ink-50 here). */}
      <svg
        viewBox="0 0 256 56"
        class="logo-lockup group-hover:brightness-110 transition-all shrink-0 text-ink-50"
        role="img"
        aria-label="Beme"
      >
        <path
          fill="#ff7a2d"
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M9 0 H95 A9 9 0 0 1 104 9 V47 A9 9 0 0 1 95 56 H9 A9 9 0 0 1 0 47 V9 A9 9 0 0 1 9 0 Z M15 11 H42 A4 4 0 0 1 46 15 V41 A4 4 0 0 1 42 45 H15 A4 4 0 0 1 11 41 V15 A4 4 0 0 1 15 11 Z M62 11 H89 A4 4 0 0 1 93 15 V41 A4 4 0 0 1 89 45 H62 A4 4 0 0 1 58 41 V15 A4 4 0 0 1 62 11 Z"
        ></path>
        <text
          x="126"
          y="29"
          dominant-baseline="central"
          font-family="'Hanken Grotesk', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
          font-weight="700"
          font-size="44"
          letter-spacing="0.88"
          fill="currentColor"
        >BEME</text>
      </svg>
    </a>

    <div class="flex items-center gap-5">
      <nav
        class="hidden md:flex items-center gap-6 text-ink-300 font-medium text-[15px]"
        style="font-family: var(--font-sans); letter-spacing: -0.01em;"
      >
        {
          links.map((l) => (
            <a
              href={l.href}
              class="hover:text-ink-50 transition-colors"
            >
              {l.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2 shrink-0">
        <a
          href={appUrl}
          class="hidden sm:inline-block text-ink-300 hover:text-ink-50 px-3 py-1.5 transition-colors text-[15px] font-medium font-sans"
        >
          Sign in
        </a>
        <button
          type="button"
          data-checkout
          data-plan="starter"
          data-source="nav"
          class="inline-block px-4 py-2 rounded-lg bg-beme-500 hover:bg-beme-400 transition-colors cursor-pointer text-[15px] font-semibold"
          style="color: #000;"
        >
          Start free
        </button>
      </div>
    </div>
  </div>
</header>

<style is:global>
  /* Horizontal lockup, mark + wordmark drawn as one SVG. The bar tightens
     on scroll and the logo scales down a touch with it. The whole lockup is
     a single SVG now (matching the app's BemeLogo), so the wordmark scales
     as part of the unit rather than collapsing on its own. */
  .nav-inner {
    padding-block: 0.95rem;
    transition: padding 0.25s ease;
  }
  .logo-lockup {
    height: 28px;
    width: auto;
    transition: height 0.25s ease;
  }
  header.is-scrolled .nav-inner {
    padding-block: 0.55rem;
  }
  header.is-scrolled .logo-lockup {
    height: 26px;
  }
</style>

<script is:inline>
  ;(function () {
    var header = document.querySelector('header')
    if (!header) return
    function onScroll() {
      if (window.scrollY > 24) header.classList.add('is-scrolled')
      else header.classList.remove('is-scrolled')
    }
    onScroll()
    window.addEventListener('scroll', onScroll, { passive: true })
  })()
</script>
