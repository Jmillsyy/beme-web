---
// Page-bottom CTA strip. Sits before the footer to give a clear
// next-step to a reader who's read the whole page. Same pattern
// on every page so visitors learn where to click. Card chrome
// matches the dashboard's stat tiles + project cards, white-on-
// cream with a subtle border, accent stripe along the top.

interface Props {
  title?: string
  body?: string
  ctaLabel?: string
  /** Stripe plan to start when clicked. Defaults to starter (the
   *  entry tier). */
  checkoutPlan?: 'starter' | 'pro' | 'team' | 'enterprise'
  /** Source tag for analytics. Defaults from the plan. */
  checkoutSource?: string
}

const {
  title = 'Try it on a real job.',
  body = 'The fastest way to know if Beme fits is to point it at a plan you\'ve already quoted. Trace it, compare the schedule. 14-day free trial.',
  ctaLabel = 'Start free trial',
  checkoutPlan = 'starter',
  checkoutSource,
} = Astro.props

const source = checkoutSource ?? `cta-${checkoutPlan}`
---

<section class="container-tight" style="padding-block: clamp(5rem, 8vw, 10rem);">
  <div
    class="relative overflow-hidden rounded-3xl border border-ink-600 bg-ink-800 p-12 md:p-20 text-center"
    style="box-shadow: 0 16px 48px -16px rgba(0, 0, 0, 0.12);"
  >
    {/* Brand accent stripe, same as the app's dashboard accent bar. */}
    <div
      class="absolute top-0 left-0 right-0"
      style="height: 4px; background: linear-gradient(90deg, var(--color-beme-500), var(--color-beme-300));"
      aria-hidden="true"
    ></div>
    {/* Subtle radial glow so the card has SOME warmth without going dark. */}
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse at center, rgba(255, 122, 45, 0.04), transparent 70%);"
      aria-hidden="true"
    >
    </div>
    <div class="relative">
      <h2 class="text-3xl md:text-4xl font-bold text-ink-50 tracking-tight">{title}</h2>
      <p class="text-base md:text-lg text-ink-300 mt-5 max-w-xl mx-auto leading-relaxed">
        {body}
      </p>
      <button
        type="button"
        data-checkout
        data-plan={checkoutPlan}
        data-source={source}
        class="inline-block mt-10 px-7 py-3.5 rounded-lg bg-beme-500 hover:bg-beme-400 transition-colors font-semibold cursor-pointer"
        style="color: #000;"
      >
        {ctaLabel}
      </button>
    </div>
  </div>
</section>
