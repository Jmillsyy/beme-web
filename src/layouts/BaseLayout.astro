---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  /** Browser tab title, page-specific, e.g. "Pricing". */
  title: string
  /** Meta description for SEO + social previews. Keep under ~155 chars. */
  description?: string
  /** Per-page social image. Absolute URL or site-root path. Defaults to /og.png. */
  image?: string
  /** Set true to keep a page out of search results (e.g. 404). */
  noindex?: boolean
  /** Extra JSON-LD structured data for this page (object or array). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
}

const {
  title,
  description = 'Brick and block estimates that match what you build. Trace the plan, see the build in 3D, order with confidence.',
  image = '/og.png',
  noindex = false,
  jsonLd,
} = Astro.props

// Resolve absolute URLs against the configured site so canonical +
// social tags are always fully-qualified, whatever the page path.
const siteUrl = Astro.site ?? new URL('https://bemeapp.app')
const canonical = new URL(Astro.url.pathname, siteUrl).href
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).href

// Sitewide structured data: who Beme is and what the product is. Pages
// can layer on their own (FAQ, etc.) through the jsonLd prop.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Beme',
  url: siteUrl.href,
  logo: new URL('/favicon.svg', siteUrl).href,
  description: 'Brick and block estimating software for builders and bricklayers.',
  areaServed: 'AU',
}
const appLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Beme',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  url: siteUrl.href,
  description: 'Trace a plan, set walls up the way you lay them, see the build in 3D, and export a takeoff that matches block for block.',
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'AUD',
    lowPrice: '39',
    highPrice: '349',
  },
}
const extraLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : []
const structuredData = [orgLd, appLd, ...extraLd]

// Brand every tab title without doubling up on pages whose title
// already carries the word "Beme".
const fullTitle = title.includes('Beme') ? title : `${title} · Beme`
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    {/* Light-mode only: the `light` class is hardcoded on <html> above,
        so no theme bootstrap or toggle is needed. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Privacy-friendly analytics (Plausible). Cookie-less, so no
        consent banner needed. Stays dormant until PUBLIC_ANALYTICS_DOMAIN
        is set in the production env (Vercel), and never runs in dev. Swap
        the src for a self-hosted or Fathom endpoint if you prefer. */}
    {
      import.meta.env.PROD && import.meta.env.PUBLIC_ANALYTICS_DOMAIN && (
        <script
          defer
          data-domain={import.meta.env.PUBLIC_ANALYTICS_DOMAIN}
          src="https://plausible.io/js/script.js"
        />
      )
    }

    {/* Hanken Grotesk (UI / headings sans, our closest free match to
        Anthropic's Styrene) + Source Serif 4 (editorial serif, our Tiempos
        stand-in). preconnect first to shave the TLS handshake. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
    />

    <title>{fullTitle}</title>

    {/* Open Graph + Twitter cards. Title, description, image and url
        are all per-page; image falls back to the sitewide /og.png. */}
    <meta property="og:site_name" content="Beme" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Structured data: Organization + SoftwareApplication sitewide,
        plus anything a page passes through (FAQ, etc.). */}
    {
      structuredData.map((node) => (
        <script type="application/ld+json" set:html={JSON.stringify(node)} />
      ))
    }
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {/* Stripe Checkout wiring, every button with [data-checkout] POSTs
        to the create-checkout-session Edge Function and redirects to
        Stripe. Single delegated listener, no per-button JS. Accepted
        plan values mirror the four pricing-page tiers exactly. */}
    <script>
      import { startCheckout, type Plan } from '../lib/checkout'
      const VALID_PLANS: readonly Plan[] = ['starter', 'pro', 'team', 'enterprise']
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement)?.closest('[data-checkout]')
        if (!target) return
        e.preventDefault()
        const planAttr = target.getAttribute('data-plan')
        const source = target.getAttribute('data-source') ?? 'unknown'
        if (!planAttr || !VALID_PLANS.includes(planAttr as Plan)) {
          console.warn('[checkout] missing or invalid data-plan', target)
          return
        }
        const plan = planAttr as Plan
        // Disable the button to prevent double-clicks while we hit
        // the endpoint. Re-enable in the rare case of failure (the
        // helper redirects on success so re-enabling never runs).
        if (target instanceof HTMLButtonElement) {
          target.disabled = true
          target.style.opacity = '0.6'
        }
        void startCheckout({ plan, source })
      })
    </script>

    {/* Scroll reveal, adds `.is-visible` to elements with `.reveal`
        once they intersect the viewport. One observer for the whole
        page; unobserves after the first reveal so animation only runs
        once per element. */}
    <script is:inline>
      ;(function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('is-visible')
          })
          return
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        )
        document.querySelectorAll('.reveal').forEach(function (el) {
          io.observe(el)
        })
      })()
    </script>
  </body>
</html>
