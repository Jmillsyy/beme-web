---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

interface Props {
  /** Browser tab title — page-specific, e.g. "Pricing — Beme". */
  title: string
  /** Meta description for SEO + social previews. Keep under ~155 chars. */
  description?: string
}

const {
  title,
  description = 'Brick and block estimates that match what you build. Trace the plan, see the build in 3D, order with confidence.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    {/* Theme bootstrap — read stored preference (default: light) and
        apply the `light` class to <html> BEFORE first paint so there's
        no flash of the wrong theme. Runs synchronously in <head>. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('beme-web-theme')
          var theme = stored === 'dark' ? 'dark' : 'light'
          if (theme === 'light') document.documentElement.classList.add('light')
        } catch (e) {
          // localStorage unavailable (private mode, etc) — fall through
          // to the default and just apply light.
          document.documentElement.classList.add('light')
        }
      })()
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Inter from Google Fonts — same weights the app loads so the
        wordmark + body type render identically across marketing site
        and app. preconnect first to shave the TLS handshake. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <title>{title}</title>

    <!-- Open Graph + Twitter card defaults — same description/title
         everywhere; pages can override per-page later. -->
    <meta property="og:site_name" content="Beme" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://beme.com.au/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://beme.com.au/og.png" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {/* Stripe Checkout wiring — every button with [data-checkout] POSTs
        to the create-checkout-session Edge Function and redirects to
        Stripe. Single delegated listener, no per-button JS. */}
    <script>
      import { startCheckout } from '../lib/checkout'
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement)?.closest('[data-checkout]')
        if (!target) return
        e.preventDefault()
        const plan = target.getAttribute('data-plan') as
          | 'individual'
          | 'organisation'
          | null
        const source = target.getAttribute('data-source') ?? 'unknown'
        if (plan !== 'individual' && plan !== 'organisation') {
          console.warn('[checkout] missing or invalid data-plan', target)
          return
        }
        // Disable the button to prevent double-clicks while we hit
        // the endpoint. Re-enable in the rare case of failure (the
        // helper redirects on success so re-enabling never runs).
        if (target instanceof HTMLButtonElement) {
          target.disabled = true
          target.style.opacity = '0.6'
        }
        void startCheckout({ plan, source })
      })
    </script>

    {/* Scroll reveal — adds `.is-visible` to elements with `.reveal`
        once they intersect the viewport. One observer for the whole
        page; unobserves after the first reveal so animation only runs
        once per element. */}
    <script is:inline>
      ;(function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('is-visible')
          })
          return
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            })
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        )
        document.querySelectorAll('.reveal').forEach(function (el) {
          io.observe(el)
        })
      })()
    </script>
  </body>
</html>
